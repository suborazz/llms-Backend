APP_NAME=Institute LMS Backend
APP_ENV=production
DEBUG=false
AUTO_CREATE_TABLES=false

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/lms_db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DEFAULT_SUPER_ADMIN_EMAIL=admin@example.com
DEFAULT_SUPER_ADMIN_PASSWORD=ChangeThisStrongPassword
DEFAULT_SUPER_ADMIN_FIRST_NAME=Super
DEFAULT_SUPER_ADMIN_LAST_NAME=Admin
DEFAULT_SUPER_ADMIN_MOB_NO=9999999999

# CORS (comma-separated lists or JSON arrays)
CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_EXPOSE_HEADERS=
